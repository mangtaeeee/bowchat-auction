{
  "realm": "bowchat",
  "enabled": true,
  "displayName": "BowChat",
  "clients": [
    {
      "clientId": "auction-service",
      "name": "auction-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "auction-service-secret",
      "defaultClientScopes": [
        "user.internal.read"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "product-service",
      "name": "product-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "product-service-secret",
      "defaultClientScopes": [
        "user.internal.read"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "user-service",
      "name": "user-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "user-service-secret",
      "defaultClientScopes": [
        "user.internal.read"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "chat-service",
      "name": "chat-service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "chat-service-secret",
      "defaultClientScopes": [
        "user.internal.read"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "bowchat-login",
      "name": "bowchat-login",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "authorizationServicesEnabled": false,
      "secret": "bowchat-login-secret",
      "defaultClientScopes": [
        "email",
        "profile",
        "roles",
        "bowchat.user.claims"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "bowchat-admin",
      "name": "bowchat-admin",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "bowchat-admin-secret",
      "defaultClientScopes": [
        "roles"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "bowchat-web",
      "name": "bowchat-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "bowchat-web-secret",
      "redirectUris": [
        "http://localhost:8081/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:8081",
        "http://localhost:5173"
      ],
      "defaultClientScopes": [
        "email",
        "profile",
        "roles",
        "bowchat.user.claims"
      ],
      "optionalClientScopes": []
    }
  ],
  "clientScopes": [
    {
      "name": "user.internal.read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "user.internal.read",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "scope",
            "claim.value": "user.internal.read",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "bowchat.user.claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "userId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "userId",
            "claim.name": "userId",
            "jsonType.label": "long",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "nickname",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "nickname",
            "claim.name": "nickname",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "role",
            "claim.name": "role",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}

